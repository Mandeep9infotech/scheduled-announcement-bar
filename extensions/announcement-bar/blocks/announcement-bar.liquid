{{ 'announcement-bar.css' | asset_url | stylesheet_tag }}
<style>.scheduled-announcement h1,.scheduled-announcement h2,.scheduled-announcement h3,.scheduled-announcement p,.scheduled-announcement a,.scheduled-announcement span{color:inherit;margin:0;padding:0;}</style>

{% assign raw = shop.metafields.scheduled_bar.settings.value %}
{% if raw != blank %}
  {% assign bars = raw | parse_json %}
  {% assign now = 'now' | date: "%s" %}
  {% assign current_path = request.path %}

  {% for bar in bars %}
    {% assign start = bar.startDate | date: "%s" %}
    {% assign end = bar.endDate | date: "%s" %}

    {% if bar.enabled and now >= start and now <= end %}

      {%- comment -%}
        Page targeting:
        - If pageTargets is empty or absent → show on all pages
        - If pageTargets has entries → only show if current path matches one
        - Supports exact paths: /collections/sale
        - Supports wildcard suffix: /products/*
      {%- endcomment -%}

      {% assign should_show = true %}
      {% if bar.pageTargets and bar.pageTargets.size > 0 %}
        {% assign should_show = false %}
        {% for target in bar.pageTargets %}
          {% if target == current_path %}
            {% assign should_show = true %}
          {% else %}
            {% if target contains '*' %}
              {% assign target_prefix = target | split: '*' | first %}
              {% if current_path contains target_prefix %}
                {% assign should_show = true %}
              {% endif %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}

      {% if should_show %}
        <div
          id="announcement-{{ bar.id }}"
          data-id="{{ bar.id }}"
          data-version="{{ bar.updatedAt }}"
          class="scheduled-announcement"
          style="
            background-color: {{ bar.backgroundColor }};
            color: {{ bar.textColor }};
            padding: 12px 40px 12px 12px;
            text-align: center;
            font-weight: 600;
            position: relative;
            width: 100%;
            box-sizing: border-box;
            display: block;
            --bar-text-color: {{ bar.textColor }};
          "
        >
          {% if bar.allowHtml %}
            {{ bar.text | raw }}
          {% else %}
            {{ bar.text | escape }}
          {% endif %}

          {% if bar.dismissible %}
            <button
              data-dismiss-id="{{ bar.id }}"
              data-dismiss-version="{{ bar.updatedAt }}"
              style="
                position: absolute;
                right: 12px;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                font-size: 18px;
                cursor: pointer;
                color: inherit;
                line-height: 1;
                padding: 4px 8px;
              "
              aria-label="Dismiss announcement"
            >
              ×
            </button>
          {% endif %}
        </div>
      {% endif %}

    {% endif %}
  {% endfor %}
{% endif %}

<script>
function initAnnouncementBars() {
  // Hide already-dismissed bars
  document.querySelectorAll(".scheduled-announcement").forEach(function (el) {
    var id = el.getAttribute("data-id");
    var version = el.getAttribute("data-version");
    var storedVersion = localStorage.getItem("announcement_" + id);
    if (storedVersion && storedVersion === version) {
      el.style.display = "none";
    }
  });

  // Attach dismiss handlers
  document.querySelectorAll("[data-dismiss-id]").forEach(function (btn) {
    // Avoid attaching duplicate listeners
    if (btn.dataset.listenerAttached) return;
    btn.dataset.listenerAttached = "true";
    btn.addEventListener("click", function () {
      var id = btn.getAttribute("data-dismiss-id");
      var version = btn.getAttribute("data-dismiss-version");
      localStorage.setItem("announcement_" + id, version);
      var bar = document.getElementById("announcement-" + id);
      if (bar) {
        bar.style.transition = "opacity 0.2s";
        bar.style.opacity = "0";
        setTimeout(function () { bar.style.display = "none"; }, 200);
      }
    });
  });
}

if (document.readyState === "complete" || document.readyState === "interactive") {
  initAnnouncementBars();
} else {
  document.addEventListener("DOMContentLoaded", initAnnouncementBars);
}
</script>

{% schema %}
{
  "name": "Scheduled Announcement",
  "target": "section",
  "settings": []
}
{% endschema %}